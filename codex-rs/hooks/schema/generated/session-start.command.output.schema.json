{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "HookEventNameWire": {
      "enum": [
        "PreToolUse",
        "PostToolUse",
        "SessionStart",
        "UserPromptSubmit",
        "Stop"
      ],
      "type": "string"
    },
    "PluginUiAnimationWire": {
      "additionalProperties": false,
      "properties": {
        "idleFrameMs": {
          "default": null,
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        },
        "idleFrames": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "petFrameMs": {
          "default": null,
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        },
        "petFrames": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "reactionFrameMs": {
          "default": null,
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        },
        "reactionFrames": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "PluginUiEventWire": {
      "oneOf": [
        {
          "properties": {
            "animation": {
              "allOf": [
                {
                  "$ref": "#/definitions/PluginUiAnimationWire"
                }
              ],
              "default": null
            },
            "badge": {
              "default": null,
              "type": "string"
            },
            "color": {
              "default": null,
              "type": "string"
            },
            "event": {
              "enum": [
                "presence"
              ],
              "type": "string"
            },
            "face": {
              "default": null,
              "type": "string"
            },
            "label": {
              "default": null,
              "type": "string"
            },
            "muted": {
              "default": false,
              "type": "boolean"
            },
            "plugin": {
              "type": "string"
            },
            "reservedColumns": {
              "default": null,
              "format": "uint16",
              "minimum": 0.0,
              "type": "integer"
            },
            "species": {
              "default": null,
              "type": "string"
            },
            "subtitle": {
              "default": null,
              "type": "string"
            },
            "visible": {
              "type": "boolean"
            }
          },
          "required": [
            "event",
            "plugin",
            "visible"
          ],
          "type": "object"
        },
        {
          "properties": {
            "event": {
              "enum": [
                "reaction"
              ],
              "type": "string"
            },
            "kind": {
              "default": null,
              "type": "string"
            },
            "plugin": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "ttlMs": {
              "default": null,
              "format": "uint64",
              "minimum": 0.0,
              "type": "integer"
            }
          },
          "required": [
            "event",
            "plugin",
            "text"
          ],
          "type": "object"
        },
        {
          "properties": {
            "event": {
              "enum": [
                "pet"
              ],
              "type": "string"
            },
            "plugin": {
              "type": "string"
            },
            "ttlMs": {
              "default": null,
              "format": "uint64",
              "minimum": 0.0,
              "type": "integer"
            }
          },
          "required": [
            "event",
            "plugin"
          ],
          "type": "object"
        }
      ]
    },
    "SessionStartHookSpecificOutputWire": {
      "additionalProperties": false,
      "properties": {
        "additionalContext": {
          "default": null,
          "type": "string"
        },
        "hookEventName": {
          "$ref": "#/definitions/HookEventNameWire"
        }
      },
      "required": [
        "hookEventName"
      ],
      "type": "object"
    }
  },
  "properties": {
    "continue": {
      "default": true,
      "type": "boolean"
    },
    "hookSpecificOutput": {
      "allOf": [
        {
          "$ref": "#/definitions/SessionStartHookSpecificOutputWire"
        }
      ],
      "default": null
    },
    "pluginUiEvents": {
      "default": [],
      "items": {
        "$ref": "#/definitions/PluginUiEventWire"
      },
      "type": "array"
    },
    "stopReason": {
      "default": null,
      "type": "string"
    },
    "suppressOutput": {
      "default": false,
      "type": "boolean"
    },
    "systemMessage": {
      "default": null,
      "type": "string"
    }
  },
  "title": "session-start.command.output",
  "type": "object"
}